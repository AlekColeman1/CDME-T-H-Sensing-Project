@app.route("/api/set_thresholds", methods=["POST"])
def set_thresholds():
    data = request.json
    sensor = data["sensor"]

    settings = load_settings()

    if "SENSOR-LIMITS" not in settings:
        settings["SENSOR-LIMITS"] = {}

    settings["SENSOR-LIMITS"][sensor] = {
        "temp_min": float(data["temp_min"]),
        "temp_max": float(data["temp_max"]),
        "hum_min": float(data["hum_min"]),
        "hum_max": float(data["hum_max"])
    }

    save_settings(settings)


    ])

@app.route("/api/live")
def api_live():

    sensor = request.args.get("sensor", "SEN0438:avg")
    rows = load_data_from_db(sensor)
    rows_sen1 = load_data_from_db("SEN0438:1")
    rows_sen2 = load_data_from_db("SEN0438:2")
    rows_sen3 = load_data_from_db("SEN0438:3")
    rows_sen4 = load_data_from_db("SEN0438:4")

    if not rows:
        return jsonify({})

    latest = rows[-1]
   
    SENSORS = ["SEN0438:1", "SEN0438:2", "SEN0438:3", "SEN0438:4"]
    for sensor_id in SENSORS:
        rows_sensor = load_data_from_db(sensor_id)
        if not rows_sensor:
            continue
        latest_sensor = rows_sensor[-1]
        alarms,warnings = check_sensor_alarm(
            sensor_id,
            latest_sensor["Temperature"],
            latest_sensor["Humidity"]
        )

        print(f"{sensor_id} -> Alarms: {alarms}, Warnings: {warnings}")
        if alarms:
            if not LAST_ALERT_STATE.get(sensor_id, False):
                send_email_alert(
                    sensor_id,
                    alarms,
                    latest_sensor["Temperature"],
                    latest_sensor["Humidity"],
                    latest_sensor["Time"]
                )
                LAST_ALERT_STATE[sensor_id] = True
        else:
            LAST_ALERT_STATE[sensor_id] = False
    return jsonify({
        "Time": latest["Time"].isoformat(),
        "Temperature": latest["Temperature"],
        "Humidity": latest["Humidity"],
        "alarms": alarms,
        "warnings": warnings
    })


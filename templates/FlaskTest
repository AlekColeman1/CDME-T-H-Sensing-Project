@app.route("/api/set_thresholds", methods=["POST"])
def set_thresholds():
    data = request.json
    sensor = data["sensor"]

    SENSOR_LIMITS[sensor] = {
        "temp_min": data["temp_min"],
        "temp_max": data["temp_max"],
        "hum_min": data["hum_min"],
        "hum_max": data["hum_max"]
    }

    return jsonify({"status": "success"})

